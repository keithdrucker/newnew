# Required.
# Postgres connection string for the API server, the schema sync tool,
# and the data import. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DATABASE
# For Neon, include SSL mode like:
#   postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/servicehub

# Required.
# Used to sign session cookies for the API server. Pick a long random string
# (e.g. `openssl rand -hex 32`). Sessions become invalid if this changes.
SESSION_SECRET=replace-me-with-a-long-random-string

# Optional. Defaults shown.
# NODE_ENV    -> development | production    (production turns off pretty logs)
# LOG_LEVEL   -> info                        (debug | info | warn | error)
# PORT        -> picked by each artifact     (override only if you need a fixed port)
# BASE_PATH   -> /                           (path prefix the artifact is mounted at)
